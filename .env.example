# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — created automatically by install.sh
DATABASE_URL=postgresql://itrm:CHANGE_ME@localhost:5432/itrm_presales

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: random string ≥ 32 chars. Generate with:  openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# One-time seed secret — used only on first run, then remove or leave blank
SEED_SECRET=CHANGE_ME_SEED_SECRET

# Default password set on all seed users (change immediately after first login)
SEED_DEFAULT_PASSWORD=Presales@2026!

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001

# Public URL of the app (used in password reset links and SAML callback)
APP_URL=https://your-domain.example.com

# ─── Optional SAML/SSO ────────────────────────────────────────────────────────
# SAML_ENTRY_POINT=https://your-idp.example.com/saml/login
# SAML_ISSUER=itrm-presales
# SAML_IDP_CERT=<base64-encoded-cert>

# ─── CORS (optional — defaults to same-origin) ────────────────────────────────
# CORS_ORIGIN=https://your-domain.example.com
